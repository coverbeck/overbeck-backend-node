{% extends "layouts/base.njk" %}

{% block title %}Weather{% endblock %}

{% block content %}
<h1>My Weather</h1>
<p>
  I have an <a href="https://ambientweather.com/amws2902.html">Ambient Weather Station</a>.
  Here are its readings:
</p>

{% if weather %}
<p>
  Outdoor temperature (F): {{ weather.outdoorTemp }}<br>
  Indoor temperature (F): {{ weather.indoorTemp }}<br>
  Windspeed (MPH): {{ weather.windSpeedMph }}<br>
  Wind direction (degrees from which the wind is blowing): {{ weather.windDirection }}&deg;<br>
  Daily rain: {{ weather.dailyRain }}<br>
  Reading time: <span id="reading-time" data-iso="{{ weather.date }}"></span>
</p>
{% else %}
<p>Weather station data is currently unavailable ({{ weatherError }}).</p>
{% endif %}

{% if weather and googleMapsApiKey and weatherMapLat and weatherMapLon %}
<h2>Wind Direction</h2>
<div id="weather-map" style="max-width: 700px; height: 400px;"></div>
<p>
  <small>
    Red arrow is my station, at an approximate location (not its exact position).
    Blue arrows are the two public stations nearest {{ parks.derby.name }}; green arrows are the two nearest {{ parks.brommer.name }}.
    Larger arrows mean higher wind speed.
  </small>
</p>
{% endif %}

<h2>Loch Lomond Reservoir Level</h2>
<div style="max-width: 700px">
  <canvas id="lochlomond-chart"></canvas>
</div>
<p>
  Data screen scraped from
  <a href="https://www.santacruzca.gov/Government/City-Departments/Water-Department/Your-Water/Weekly-Water-Conditions">here</a>.
</p>
<p>Last checked: {{ lastChecked }}</p>
{% endblock %}

{% block head %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
{% endblock %}

{% block scripts %}
<script>
  const readingTimeEl = document.getElementById('reading-time');
  if (readingTimeEl) {
    const readingDate = new Date(readingTimeEl.dataset.iso);
    readingTimeEl.textContent = new Intl.DateTimeFormat(undefined, {
      year: '2-digit',
      month: 'numeric',
      day: 'numeric',
      hour: 'numeric',
      minute: '2-digit',
      hour12: true,
    }).format(readingDate);
  }

  const labels = {{ labels | dump | safe }};
  const values = {{ values | dump | safe }};

  new Chart(document.getElementById('lochlomond-chart'), {
    type: 'line',
    data: {
      datasets: [{
        label: 'Reservoir Level (%)',
        data: labels.map((date, i) => ({ x: date, y: values[i] })),
        fill: true,
      }],
    },
    options: {
      scales: {
        x: {
          type: 'time',
          time: { unit: 'month' },
        },
      },
    },
  });

  {% if weather and googleMapsApiKey and weatherMapLat and weatherMapLon %}
  const windMarkers = [
    {
      lat: {{ weatherMapLat }},
      lon: {{ weatherMapLon }},
      windDirection: {{ weather.windDirection }},
      windSpeedMph: {{ weather.windSpeedMph }},
      label: 'Me',
      fillColor: '#ff0000',
      strokeColor: '#b71c1c',
    },
    {% for station in referenceStations %}
    {
      lat: {{ station.lat }},
      lon: {{ station.lon }},
      windDirection: {{ station.windDirection }},
      windSpeedMph: {{ station.windSpeedMph }},
      label: {{ station.name | dump | safe }},
      fillColor: '{{ "#1a73e8" if station.group == "derby" else "#2e7d32" }}',
      strokeColor: '{{ "#0b3d91" if station.group == "derby" else "#1b4d20" }}',
    },
    {% endfor %}
  ];

  const parkPoints = [
    { lat: {{ parks.derby.lat }}, lng: {{ parks.derby.lon }} },
    { lat: {{ parks.brommer.lat }}, lng: {{ parks.brommer.lon }} },
  ];

  // Higher wind speed -> bigger arrow, capped so gusty readings don't dominate the map.
  function arrowScale(windSpeedMph) {
    return Math.min(1 + windSpeedMph * 0.15, 3.5);
  }

  function addWindMarker(map, marker) {
    const position = { lat: marker.lat, lng: marker.lon };
    // windDirection is the compass bearing the wind is blowing FROM; rotate
    // 180deg so the arrow points in the direction the wind is blowing TOWARD.
    const rotation = (marker.windDirection + 180) % 360;

    new google.maps.Marker({
      position,
      map,
      icon: {
        path: 'M 0,-10 L 6,8 L 0,4 L -6,8 Z',
        fillColor: marker.fillColor,
        fillOpacity: 1,
        strokeColor: marker.strokeColor,
        strokeWeight: 1,
        scale: arrowScale(marker.windSpeedMph),
        rotation,
        anchor: new google.maps.Point(0, 0),
        labelOrigin: new google.maps.Point(0, -18),
      },
      label: {
        text: marker.windDirection + '° · ' + marker.windSpeedMph + ' mph',
        color: '#202020',
        fontSize: '13px',
        fontWeight: 'bold',
        className: 'weather-map-label',
      },
      title: marker.label + ': wind direction (blowing toward)',
    });

    return position;
  }

  window.initWeatherMap = function initWeatherMap() {
    const map = new google.maps.Map(document.getElementById('weather-map'), {
      mapTypeControl: false,
      streetViewControl: false,
    });

    const bounds = new google.maps.LatLngBounds();
    windMarkers.forEach((marker) => bounds.extend(addWindMarker(map, marker)));
    parkPoints.forEach((point) => bounds.extend(point));
    map.fitBounds(bounds, 40);
  };
  {% endif %}
</script>
{% if weather and googleMapsApiKey and weatherMapLat and weatherMapLon %}
<script src="https://maps.googleapis.com/maps/api/js?key={{ googleMapsApiKey }}&callback=initWeatherMap"></script>
{% endif %}
{% endblock %}
